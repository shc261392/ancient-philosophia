---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/civilizations/', label: 'Civilizations' },
  { href: '/languages/', label: 'Languages' },
  { href: '/mindmap/', label: 'Mindmap' },
  { href: '/resources/', label: 'Resources' },
  { href: '/roadmap/', label: 'Roadmap' },
];
---

<header class="sticky top-0 z-50 bg-[var(--color-bg-secondary)]/95 backdrop-blur-sm border-b border-[var(--color-bg-tertiary)]">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 text-[var(--color-gold-leaf)] hover:text-[var(--color-gold-light)] font-serif font-bold text-lg tracking-wide">
        <img src="/favicon.svg" alt="" class="w-8 h-8" />
        <span class="hidden sm:inline">Aristeia & Philotimia</span>
        <span class="sm:hidden">A&P</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-1">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-[var(--color-gold-leaf)] bg-[var(--color-bg-tertiary)]'
                  : 'text-[var(--color-fg-secondary)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-tertiary)]/50',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-md text-[var(--color-fg-secondary)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-tertiary)]"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="md:hidden hidden pb-4">
      <ul class="space-y-1">
        {links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'block px-3 py-2 rounded-md text-base font-medium',
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-[var(--color-gold-leaf)] bg-[var(--color-bg-tertiary)]'
                  : 'text-[var(--color-fg-secondary)] hover:text-[var(--color-fg-primary)] hover:bg-[var(--color-bg-tertiary)]/50',
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
