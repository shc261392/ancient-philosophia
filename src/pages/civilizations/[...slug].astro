---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EditOnGitHub from '../../components/EditOnGitHub.astro';
import CitationLegend from '../../components/CitationLegend.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const civs = await getCollection('civilizations');
  return civs.map((civ) => ({
    params: { slug: civ.id },
    props: { civ },
  }));
}

type Props = Awaited<ReturnType<typeof getStaticPaths>>[number]['props'];

const { civ } = Astro.props;
const { Content, headings } = await render(civ);
---

<BaseLayout
  title={civ.data.title}
  description={civ.data.description}
  type="article"
>
  <article class="max-w-4xl mx-auto">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4 text-sm">
        <span class="bg-[var(--color-bg-tertiary)] px-3 py-1 rounded text-[var(--color-fg-secondary)]">{civ.data.region}</span>
        <span class="bg-[var(--color-bg-tertiary)] px-3 py-1 rounded text-[var(--color-fg-secondary)]">{civ.data.dateRange}</span>
        <span class="bg-[var(--color-bg-tertiary)] px-3 py-1 rounded text-[var(--color-fg-secondary)]">{civ.data.period}</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-[var(--color-gold-leaf)] tracking-tight mb-4">
        {civ.data.title}
      </h1>
      <p class="text-lg text-[var(--color-fg-secondary)] leading-relaxed">
        {civ.data.description}
      </p>
      <div class="mt-4 border-meander max-w-xs"></div>
    </header>

    <!-- Table of contents -->
    {headings.length > 0 && (
      <nav class="bg-[var(--color-bg-card)] rounded-xl p-6 border border-[var(--color-bg-tertiary)] mb-8">
        <h2 class="text-sm font-semibold text-[var(--color-fg-muted)] uppercase tracking-wide mb-3">Contents</h2>
        <ul class="space-y-1">
          {headings.map((h) => (
            <li style={`margin-left: ${(h.depth - 2) * 1}rem`}>
              <a href={`#${h.slug}`} class="text-sm text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <!-- Citation Legend -->
    <CitationLegend />

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <!-- Tags -->
    {civ.data.tags.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {civ.data.tags.map(tag => (
          <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-attic-red)]/20 text-[var(--color-fg-secondary)]">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Collaboration -->
    <EditOnGitHub filePath={`src/content/civilizations/${civ.id}.mdx`} collection="civilizations" />

    <!-- Back link -->
    <div class="mt-12 pt-8 border-t border-[var(--color-bg-tertiary)]">
      <a href="/civilizations/" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] text-sm">
        ← Back to all civilizations
      </a>
    </div>
  </article>
</BaseLayout>
