---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const myths = await getCollection('myths');
  return myths.map((myth) => ({
    params: { slug: myth.id },
    props: { myth },
  }));
}

type Props = Awaited<ReturnType<typeof getStaticPaths>>[number]['props'];

const { myth } = Astro.props;
const { Content, headings } = await render(myth);

const traditionColors: Record<string, string> = {
  'Mesopotamian': 'bg-[var(--color-gold-leaf)]/20 text-[var(--color-gold-light)]',
  'Egyptian': 'bg-[var(--color-terracotta)]/20 text-[var(--color-terracotta-light)]',
  'Greek': 'bg-[var(--color-aegean)]/20 text-[var(--color-aegean-light)]',
  'Roman': 'bg-[var(--color-attic-red)]/20 text-[var(--color-fg-secondary)]',
  'Zoroastrian': 'bg-[var(--color-bronze)]/20 text-[var(--color-bronze-light)]',
  'Canaanite/Phoenician': 'bg-[var(--color-gold-leaf)]/20 text-[var(--color-gold-light)]',
  'Hittite': 'bg-[var(--color-bronze)]/20 text-[var(--color-bronze-light)]',
  'Phrygian': 'bg-[var(--color-marble)]/20 text-[var(--color-marble)]',
};

const categoryLabels: Record<string, string> = {
  'pantheon': '🏛 Pantheon',
  'religion': '🔥 Religion',
  'epic': '📜 Epic',
  'myth': '🌊 Myth',
  'hero': '⚔ Hero',
  'deity': '✨ Deity',
};
---

<BaseLayout
  title={myth.data.title}
  description={myth.data.description}
  type="article"
>
  <article class="max-w-4xl mx-auto">
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-4 text-sm">
        <span class="bg-[var(--color-bg-tertiary)] px-3 py-1 rounded text-[var(--color-fg-secondary)]">
          {categoryLabels[myth.data.category] || myth.data.category}
        </span>
        <span class:list={['px-3 py-1 rounded', traditionColors[myth.data.tradition] || 'bg-[var(--color-bg-tertiary)] text-[var(--color-fg-secondary)]']}>
          {myth.data.tradition}
        </span>
        {myth.data.period && (
          <span class="bg-[var(--color-bg-tertiary)] px-3 py-1 rounded text-[var(--color-fg-secondary)]">
            {myth.data.period}
          </span>
        )}
      </div>
      <h1 class="text-4xl sm:text-5xl font-serif font-bold text-[var(--color-gold-leaf)] tracking-tight mb-4">
        {myth.data.title}
      </h1>
      <p class="text-lg text-[var(--color-fg-secondary)] leading-relaxed">
        {myth.data.description}
      </p>
      <div class="mt-4 border-meander max-w-xs"></div>
    </header>

    {headings.length > 0 && (
      <nav class="bg-[var(--color-bg-card)] rounded-xl p-6 border border-[var(--color-bg-tertiary)] mb-8">
        <h2 class="text-sm font-semibold text-[var(--color-fg-muted)] uppercase tracking-wide mb-3">Contents</h2>
        <ul class="space-y-1">
          {headings.map((h) => (
            <li style={`margin-left: ${(h.depth - 2) * 1}rem`}>
              <a href={`#${h.slug}`} class="text-sm text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <div class="mt-12 pt-8 border-t border-[var(--color-bg-tertiary)]">
      <a href="/myths/" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] text-sm">
        ← Back to Myths & Religions
      </a>
    </div>
  </article>
</BaseLayout>
