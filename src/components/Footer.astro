---
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-bg-tertiary)] bg-[var(--color-bg-secondary)] mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About -->
      <div>
        <h3 class="text-[var(--color-gold-leaf)] font-serif text-lg mb-3">Aristeia & Philotimia</h3>
        <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">
          An open educational resource for exploring ancient history and learning the languages
          of civilizations from Sumer to Rome.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-[var(--color-gold-leaf)] font-serif text-lg mb-3">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/civilizations/" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">Civilizations</a></li>
          <li><a href="/languages/" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">Languages</a></li>
          <li><a href="/mindmap/" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">Learning Mindmap</a></li>
          <li><a href="/resources/" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">Resources</a></li>
        </ul>
      </div>

      <!-- Legal / Source -->
      <div>
        <h3 class="text-[var(--color-gold-leaf)] font-serif text-lg mb-3">Open Source</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://github.com/shc261392/aristeia-and-philotimia" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]" rel="noopener noreferrer" target="_blank">GitHub Repository</a></li>
          <li><a href="/roadmap/" class="text-[var(--color-fg-secondary)] hover:text-[var(--color-link)]">Product Roadmap</a></li>
          <li class="text-[var(--color-fg-muted)]">Site code: GPL-3.0</li>
          <li class="text-[var(--color-fg-muted)]">Content: see source attribution</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[var(--color-bg-tertiary)] mt-8 pt-8 text-center text-xs text-[var(--color-fg-muted)]">
      <p>&copy; {year} Aristeia & Philotimia contributors. Site code licensed under GPL-3.0.</p>
      <p class="mt-1">Made with <a href="https://astro.build" class="hover:text-[var(--color-link)]" rel="noopener noreferrer" target="_blank">Astro</a> &amp; deployed on <a href="https://workers.cloudflare.com" class="hover:text-[var(--color-link)]" rel="noopener noreferrer" target="_blank">Cloudflare Workers</a>.</p>
    </div>
  </div>
</footer>
