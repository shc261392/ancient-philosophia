# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# wrangler local state
.wrangler/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
# .env (local plaintext) is never committed
.env
# .env.production is committed ONLY after dotenvx encryption
# (run: pnpm dotenvx encrypt -f .env.production)
# Until then, keep it ignored so plaintext secrets aren't accidentally staged.
# Remove this line after encrypting and add to git with: git add .env.production
.env.production
# dotenvx local private-key files — never commit these
.env.keys
.env.*.keys

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/
