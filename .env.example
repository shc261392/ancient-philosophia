# ─── Cloudflare deployment credentials ────────────────────────────────────────
# Copy this file to .env.production and fill in real values.
# Then encrypt it with: pnpm dotenvx encrypt -f .env.production
# The encrypted .env.production is safe to commit. The private key
# that dotenvx writes to .env.keys must NEVER be committed — add it
# as the DOTENV_PRIVATE_KEY_PRODUCTION secret in your GitHub repository.

# Cloudflare API token (scope: Edit Cloudflare Workers)
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare account ID (visible in the right sidebar of the Workers dashboard)
CLOUDFLARE_ACCOUNT_ID=
