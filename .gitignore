# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# wrangler local state
.wrangler/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
# .env (local plaintext) is never committed
.env
# .env.production is committed ONLY after dotenvx encryption
# dotenvx local private-key files — never commit these
.env.keys
.env.*.keys

# Lighthouse CI — reports and temp Chrome profiles
.lighthouseci/
C:\Users\*/

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Python virtual environments
.venv/
scripts/.venv/
__pycache__/
*.pyc

# Evaluation reports (regenerated by scripts)
scripts/citation-health-report.json
